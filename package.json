{
  "name": "quality-report-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true}); for (const p of ['packages/report-core','packages/adapters','packages/report-cli','packages/report-ui']) require('fs').rmSync(p + '/dist',{recursive:true,force:true})\"",
    "dev:ui": "npm --workspace @quality-report/report-ui run dev",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "typecheck": "tsc -b",
    "quality-report": "node packages/report-cli/dist/index.js"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@playwright/test": "^1.53.2",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.13.14",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.30.1",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-vue": "^10.3.0",
    "globals": "^16.3.0",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1",
    "vite": "^7.0.2",
    "vitest": "^3.2.4",
    "vue-tsc": "^2.2.10"
  }
}
