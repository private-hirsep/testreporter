{
  "name": "quality-report-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build:core && npm run build:adapters && npm run build:cli && npm run build:ui",
    "build:core": "npm run build --workspace @quality-report/report-core",
    "build:adapters": "npm run build --workspace @quality-report/adapters",
    "build:cli": "npm run build --workspace @quality-report/report-cli",
    "build:ui": "npm run build --workspace @quality-report/report-ui",
    "clean": "node scripts/clean.mjs",
    "dev:ui": "npm --workspace @quality-report/report-ui run dev",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check:workflows-docs": "node scripts/check-workflows-docs.mjs",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "typecheck": "tsc -b",
    "quality-report": "node packages/report-cli/dist/index.js"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@playwright/test": "^1.53.2",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.13.14",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.30.1",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-vue": "^10.3.0",
    "globals": "^16.3.0",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1",
    "vite": "^7.0.2",
    "vitest": "^4.1.10",
    "vue-tsc": "^2.2.10"
  }
}
